{
  "name": "@preconst/workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node ./packages/preconst/src/cli.ts clean && tsc -b tsconfig.preconst.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0"
    },
    "runtime": {
      "name": "node",
      "version": "26.5"
    }
  },
  "preconst": {
    "packages": [
      "packages/*"
    ]
  }
}
